{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/BioimageAnalysisCoreWEHI/uniform_batch_correction/main/assets/schema_input.json",
  "title": "uniform_batch_correction input schema",
  "description": "Samplesheet schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["sample"],
    "anyOf": [
      { "required": ["geojson"] },
      { "required": ["ome_tiff"] },
      { "required": ["adata"] }
    ],
    "properties": {
      "sample": {
        "type": "string",
        "description": "Sample identifier"
      },
      "geojson": {
        "type": "string",
        "format": "file-path",
        "description": "Path to cellmeasurement GeoJSON"
      },
      "ome_tiff": {
        "type": "string",
        "format": "file-path",
        "description": "Path to input OME-TIFF/TIFF for pixel-level normalization"
      },
      "adata": {
        "type": "string",
        "format": "file-path",
        "description": "Path to input AnnData (.h5ad) for feature-level normalization"
      }
    }
  }
}
