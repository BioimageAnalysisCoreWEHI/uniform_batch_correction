nextflow_process {

    name "Test Process UNIFORMNORMALIZE"
    script "../main.nf"
    process "UNIFORMNORMALIZE"

    tag "modules"
    tag "modules_local"
    tag "uniformnormalize"

    test("uniformnormalize - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    file('${projectDir}/modules/local/uniformnormalize/tests/test.geojson')
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
